# Snap sync — lightweight node for wallets and transactions
# Use this on machines with ~1.5TB SSD

# Data paths
GETH_DATA_DIR=./data/geth
LIGHTHOUSE_DATA_DIR=./data/lighthouse
VALIDATOR_DATA_DIR=./data/validator

# Geth sync mode
GETH_SYNCMODE=snap
GETH_GCMODE=full
GETH_CACHE=4096
GETH_MAXPEERS=50
GETH_HTTP_API=eth,net,web3,txpool
