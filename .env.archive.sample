# Archive sync — full history for explorer and historical queries
# Use this on machines with 2TB+ SSD and 32GB+ RAM

# Data paths — relative to this directory, portable
GETH_DATA_DIR=./data/geth
LIGHTHOUSE_DATA_DIR=./data/lighthouse
VALIDATOR_DATA_DIR=./data/validator
EXPLORER_DB_DIR=./data/explorer-db

# Geth sync mode
GETH_SYNCMODE=full
GETH_GCMODE=archive
GETH_CACHE=16384
GETH_MAXPEERS=50
GETH_HTTP_API=eth,net,web3,txpool,debug,trace

# Explorer frontend — set to this machine's LAN IP so browser can reach the API
# Only needed if using explorer (./eth.sh explorer on)
EXPLORER_HOST=10.0.0.50
